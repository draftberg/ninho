# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (Project Settings → API → service_role) — só usada no
# cron de lembretes (src/app/api/cron/lembretes), nunca exposta ao cliente
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini (para a importação de extrato com IA) — chave gratuita em aistudio.google.com
GEMINI_API_KEY=
# Opcional — modelo usado na extração/categorização e nos insights (padrão: gemini-flash-latest)
GEMINI_MODEL=

# Lembretes ativos (push notifications) — gere com: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu-email@exemplo.com
# Segredo que só a Vercel deve conhecer, pra autenticar a chamada do cron
CRON_SECRET=
